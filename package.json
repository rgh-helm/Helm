{
  "name": "helm",
  "private": true,
  "version": "0.51.5",
  "description": "A local-only personal finance tracker for house savings and emergency fund goals.",
  "author": "Riley Hansen <gridironhero@gmail.com>",
  "homepage": "github.com",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "wait-on tcp:5173 && electron .",
    "electron:dev": "concurrently -k \"npm:dev\" \"npm:electron:start\"",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux deb",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:all": "npm run build && electron-builder --mac dmg --win nsis --linux deb",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:feature": "npm version minor && git push --follow-tags",
    "release:bug": "npm version patch && git push --follow-tags"
  },
  "dependencies": {
    "chart.js": "^4.4.4",
    "pinia": "^2.2.2",
    "vue": "^3.5.0",
    "vue-chartjs": "^5.3.1",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-vue": "^5.1.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "daisyui": "^4.12.10",
    "electron": "^31.3.1",
    "electron-builder": "^26.15.3",
    "png2icons": "^2.0.1",
    "postcss": "^8.4.41",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.usehelm.helm",
    "productName": "Helm",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Office",
      "icon": "build/icons/icon.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance",
      "icon": "build/icons/mac/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    }
  }
}
